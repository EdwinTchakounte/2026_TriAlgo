@startuml TRIALGO_Entites

' =============================================================
' DIAGRAMME DE CLASSES DES ENTITES — TRIALGO v3.1
' =============================================================
' Uniquement les entites du systeme avec leurs relations.
' Les elements [NEW] comblent les ecarts wireframes <-> backend.
' =============================================================

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 60

skinparam class {
  BackgroundColor #1A1A2E
  BorderColor #FF6B35
  FontColor #FFFFFF
  AttributeFontColor #CCCCCC
  StereotypeFontColor #F7C948
  ArrowColor #42A5F5
  HeaderBackgroundColor #16213E
}

skinparam note {
  BackgroundColor #2A1A0A
  BorderColor #FF6B35
  FontColor #FFFFFF
}

skinparam enum {
  BackgroundColor #16213E
  BorderColor #F7C948
  FontColor #FFFFFF
}

title **TRIALGO v3.1 — Diagramme de Classes des Entites**\n(avec corrections wireframes ↔ backend)

' =============================================================
' ENUM
' =============================================================

enum CardType {
  emettrice
  cable
  receptrice
}

' =============================================================
' ENTITE : CardEntity
' =============================================================

class CardEntity {
  + id : String
  + cardType : CardType
  + distanceLevel : int {1..3}
  + imagePath : String
  + imageWidth : int?
  + imageHeight : int?
  + imageFormat : String = "webp"
  + cableCategory : String?
  + themeTags : List<String>
  + parentEmettriceId : String?
  + parentCableId : String?
  + rootEmettriceId : String?
  + difficultyScore : double = 0.5
  + isActive : bool = true
  **+ label : String  [NEW]**
  --
  + <<get>> imageUrl : String
  + <<get>> isRootEmettrice : bool
  + <<get>> isCable : bool
  + <<get>> isReceptrice : bool
}

note right of CardEntity
  **[NEW] label** : nom affichable
  de la carte ("Lion", "Miroir"...).
  Utilise dans le jeu, la galerie
  et les choix de la ScrollView.
  Correspond a une colonne
  **label TEXT** dans la table cards.
end note

' =============================================================
' ENTITE : CardTrioEntity
' =============================================================

class CardTrioEntity {
  + id : String
  + emettriceId : String
  + cableId : String
  + receptriceId : String
  + distanceLevel : int {1..3}
  + parentTrioId : String?
  + difficulty : double = 0.5
}

' =============================================================
' ENTITE : UserEntity
' =============================================================

class UserEntity {
  + id : String
  + username : String
  + avatarUrl : String?
  + totalScore : int
  + currentLevel : int
  + lives : int {0..5}
  + livesLastRefill : DateTime?
}

' =============================================================
' ENTITE : GameQuestionEntity
' =============================================================

class GameQuestionEntity {
  + visibleCards : List<CardEntity> {size=2}
  + maskedCard : CardEntity
  + choices : List<CardEntity> {size=10}
  + config : String {"A"|"B"|"C"}
  + correctCardId : String
  + trioId : String
  + timeLimitSeconds : int
}

' =============================================================
' ENTITE : GameSessionEntity [NEW]
' =============================================================

class GameSessionEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + levelNumber : int
  + score : int = 0
  + correctAnswers : int = 0
  + wrongAnswers : int = 0
  + bonusEarned : int = 0
  + malusReceived : int = 0
  + durationSeconds : int?
  + completed : bool = false
  **+ passed : bool = false  [NEW]**
  **+ totalQuestions : int  [NEW]**
  **+ maxStreak : int = 0  [NEW]**
  + startedAt : DateTime
  + endedAt : DateTime?
}

note left of GameSessionEntity
  **[NEW] Entite manquante.**
  Le code existant utilisait
  Map<String, dynamic> au lieu
  d'une vraie entite.
  --
  Ajouts pour les wireframes :
  • **passed** : niveau reussi ?
  • **totalQuestions** : nb total
  • **maxStreak** : meilleure serie
end note

' =============================================================
' ENTITE : UserLevelProgressEntity [NEW]
' =============================================================

class UserLevelProgressEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + levelNumber : int
  + stars : int {0..3}
  + bestScore : int = 0
  + completed : bool = false
  + completedAt : DateTime?
}

note right of UserLevelProgressEntity
  **[NEW] Table + entite a creer.**
  Stocke la progression par niveau :
  etoiles obtenues, meilleur score,
  completion. Requis par le wireframe
  **level_map** et **game_result**.
end note

' =============================================================
' ENTITE : ActivationCodeEntity [NEW]
' =============================================================

class ActivationCodeEntity <<NEW>> #2A1A0A {
  + id : String
  + codeValue : String
  + isActivated : bool = false
  + deviceId : String?
  + userId : String?
  + activatedAt : DateTime?
}

note bottom of ActivationCodeEntity
  **[NEW] Entite manquante.**
  Le code existant utilisait
  directement l'Edge Function
  sans entite structuree.
end note

' =============================================================
' ENTITE : UnlockedCardEntity [NEW]
' =============================================================

class UnlockedCardEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + cardId : String
  + unlockedAt : DateTime
  + unlockCount : int = 1
}

note bottom of UnlockedCardEntity
  **[NEW] Entite pour la galerie.**
  Represente une carte debloquee
  par un joueur. Correspond a la
  table **user_unlocked_cards**.
end note

' =============================================================
' ENTITE : LevelConfig (Core — incluse car reference directe)
' =============================================================

class LevelConfig <<core>> #0D1A2E {
  + distance : int
  + configs : List<String>
  + questions : int
  + threshold : int
  + livesPerWrong : int
  + turnTimeSeconds : int
  + basePoints : int
}

' =============================================================
' RELATIONS
' =============================================================

' --- CardEntity ---
CardEntity --> CardType : cardType
CardEntity "0..1" --> "0..1" CardEntity : parentEmettriceId\n(auto-reference)
CardEntity "0..1" --> "0..1" CardEntity : parentCableId\n(auto-reference)
CardEntity "0..1" --> "0..1" CardEntity : rootEmettriceId\n(auto-reference)

' --- CardTrioEntity ---
CardTrioEntity "1" --> "1" CardEntity : emettriceId\n(E)
CardTrioEntity "1" --> "1" CardEntity : cableId\n(C)
CardTrioEntity "1" --> "1" CardEntity : receptriceId\n(R)
CardTrioEntity "0..1" --> "0..1" CardTrioEntity : parentTrioId\n(chaine D1→D2→D3)

' --- GameQuestionEntity ---
GameQuestionEntity "1" *-- "2" CardEntity : visibleCards
GameQuestionEntity "1" *-- "1" CardEntity : maskedCard
GameQuestionEntity "1" *-- "10" CardEntity : choices
GameQuestionEntity "1" --> "1" CardTrioEntity : trioId
GameQuestionEntity ..> LevelConfig : timeLimitSeconds\n(derive de)

' --- GameSessionEntity ---
GameSessionEntity "0..*" --> "1" UserEntity : userId
GameSessionEntity ..> LevelConfig : levelNumber\n(derive config de)

' --- UserLevelProgressEntity ---
UserLevelProgressEntity "0..*" --> "1" UserEntity : userId
UserLevelProgressEntity ..> GameSessionEntity : calcule depuis\nmeilleure session

' --- ActivationCodeEntity ---
ActivationCodeEntity "0..1" --> "0..1" UserEntity : userId

' --- UnlockedCardEntity ---
UnlockedCardEntity "0..*" --> "1" UserEntity : userId
UnlockedCardEntity "0..*" --> "1" CardEntity : cardId

' =============================================================
' LEGENDE
' =============================================================

legend bottom
  |= Couleur |= Signification |
  | <#1A1A2E> | Entite existante |
  | <#2A1A0A> | **[NEW]** Entite a creer |
  | <#0D1A2E> | Classe Core (reference) |
  --
  **6 corrections appliquees :**
  1. **label** ajoute dans CardEntity
  2. **GameSessionEntity** creee (remplace Map<String, dynamic>)
  3. **passed / totalQuestions / maxStreak** ajoutes dans GameSessionEntity
  4. **UserLevelProgressEntity** creee (etoiles + completion par niveau)
  5. **ActivationCodeEntity** creee (structure le code d'activation)
  6. **UnlockedCardEntity** creee (galerie des cartes debloquees)
endlegend

@enduml
