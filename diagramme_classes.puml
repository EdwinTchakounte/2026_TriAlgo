@startuml TRIALGO_Entites_v32

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 60

skinparam class {
  BackgroundColor #1A1A2E
  BorderColor #FF6B35
  FontColor #FFFFFF
  AttributeFontColor #CCCCCC
  StereotypeFontColor #F7C948
  ArrowColor #42A5F5
  HeaderBackgroundColor #16213E
}

skinparam note {
  BackgroundColor #2A1A0A
  BorderColor #FF6B35
  FontColor #FFFFFF
}

skinparam enum {
  BackgroundColor #16213E
  BorderColor #F7C948
  FontColor #FFFFFF
}

title **TRIALGO v3.2 — Diagramme de Classes des Entités**\n(Deck + Mode Individuel + Mode Collectif)

' === ENUMS ===
enum CardType {
  emettrice
  cable
  receptrice
}

enum GameMode <<NEW>> {
  solo
  coop
}

' === DECK ===
class CardDeckEntity <<NEW>> #2A1A0A {
  + id : String
  + name : String
  + description : String?
  + cardCount : int = 50
  + isActive : bool = true
}

note right of CardDeckEntity
  1 boîte physique = 1 deck.
  Toutes les cartes, trios et
  codes d'activation pointent
  vers un deck.
end note

' === CARD ===
class CardEntity {
  + id : String
  + cardType : CardType
  + distanceLevel : int {1..3}
  + imagePath : String
  + imageWidth : int?
  + imageHeight : int?
  + imageFormat : String = "webp"
  + cableCategory : String?
  + themeTags : List<String>
  + parentEmettriceId : String?
  + parentCableId : String?
  + rootEmettriceId : String?
  + difficultyScore : double = 0.5
  + isActive : bool = true
  **+ label : String [NEW]**
  **+ deckId : String [NEW]**
  **+ qrCode : String? [NEW]**
  --
  + <<get>> imageUrl : String
  + <<get>> isRootEmettrice : bool
  + <<get>> isCable : bool
  + <<get>> isReceptrice : bool
}

' === TRIO ===
class CardTrioEntity {
  + id : String
  + emettriceId : String
  + cableId : String
  + receptriceId : String
  + distanceLevel : int {1..3}
  + parentTrioId : String?
  + difficulty : double = 0.5
  **+ deckId : String [NEW]**
}

' === QUESTION (MODE INDIVIDUEL) ===
class GameQuestionEntity {
  + visibleCards : List<CardEntity> {2}
  + maskedCard : CardEntity {1}
  + choices : List<CardEntity> {10}
  + config : String {"A"|"B"|"C"}
  + correctCardId : String
  + trioId : String
  + timeLimitSeconds : int
}

' === SCAN (MODE COLLECTIF) ===
class ScanValidationEntity <<NEW>> #2A1A0A {
  + scannedCardIds : List<String> {3}
  + emettriceId : String?
  + cableId : String?
  + receptriceId : String?
  + isValid : bool
  + matchedTrioId : String?
  + deckId : String
}

note bottom of ScanValidationEntity
  Mode collectif : le joueur
  scanne 3 QR codes physiques.
  On vérifie si E+C=R dans
  le même deck.
end note

' === USER ===
class UserEntity {
  + id : String
  + username : String
  + avatarUrl : String?
  + totalScore : int
  + currentLevel : int
  + lives : int {0..5}
  + livesLastRefill : DateTime?
  **+ activeDeckId : String? [NEW]**
}

' === SESSION ===
class GameSessionEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + levelNumber : int
  + score : int = 0
  + correctAnswers : int = 0
  + wrongAnswers : int = 0
  + bonusEarned : int = 0
  + malusReceived : int = 0
  + durationSeconds : int?
  + completed : bool = false
  **+ passed : bool = false [NEW]**
  **+ totalQuestions : int [NEW]**
  **+ maxStreak : int = 0 [NEW]**
  **+ deckId : String [NEW]**
  **+ gameMode : GameMode [NEW]**
  + startedAt : DateTime
  + endedAt : DateTime?
}

' === PROGRESS ===
class UserLevelProgressEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + levelNumber : int
  + stars : int {0..3}
  + bestScore : int = 0
  + completed : bool = false
  + completedAt : DateTime?
}

' === ACTIVATION ===
class ActivationCodeEntity <<NEW>> #2A1A0A {
  + id : String
  + codeValue : String
  + isActivated : bool = false
  + deviceId : String?
  + userId : String?
  + activatedAt : DateTime?
  **+ deckId : String [NEW]**
}

' === UNLOCKED ===
class UnlockedCardEntity <<NEW>> #2A1A0A {
  + id : String
  + userId : String
  + cardId : String
  + unlockedAt : DateTime
  + unlockCount : int = 1
}

' === LEVEL CONFIG ===
class LevelConfig <<core>> #0D1A2E {
  + distance : int
  + configs : List<String>
  + questions : int
  + threshold : int
  + livesPerWrong : int
  + turnTimeSeconds : int
  + basePoints : int
}

' === RELATIONS ===

' Deck → tout
CardDeckEntity "1" --> "*" CardEntity : deckId
CardDeckEntity "1" --> "*" CardTrioEntity : deckId
CardDeckEntity "1" --> "*" ActivationCodeEntity : deckId
CardDeckEntity "1" --> "*" GameSessionEntity : deckId

' Card
CardEntity --> CardType
CardEntity "0..1" --> "0..1" CardEntity : parentEmettriceId
CardEntity "0..1" --> "0..1" CardEntity : parentCableId
CardEntity "0..1" --> "0..1" CardEntity : rootEmettriceId

' Trio → Card
CardTrioEntity "1" --> "1" CardEntity : emettriceId
CardTrioEntity "1" --> "1" CardEntity : cableId
CardTrioEntity "1" --> "1" CardEntity : receptriceId
CardTrioEntity "0..1" --> "0..1" CardTrioEntity : parentTrioId

' Question (individuel)
GameQuestionEntity "1" *-- "2" CardEntity : visibleCards
GameQuestionEntity "1" *-- "1" CardEntity : maskedCard
GameQuestionEntity "1" *-- "10" CardEntity : choices
GameQuestionEntity "1" --> "1" CardTrioEntity : trioId

' Scan (collectif)
ScanValidationEntity "1" --> "3" CardEntity : scannedCardIds
ScanValidationEntity "0..1" --> "0..1" CardTrioEntity : matchedTrioId
ScanValidationEntity "1" --> "1" CardDeckEntity : deckId

' User
UserEntity "0..1" --> "0..1" CardDeckEntity : activeDeckId
GameSessionEntity "*" --> "1" UserEntity : userId
GameSessionEntity --> GameMode
UserLevelProgressEntity "*" --> "1" UserEntity : userId
ActivationCodeEntity "0..1" --> "0..1" UserEntity : userId
UnlockedCardEntity "*" --> "1" UserEntity : userId
UnlockedCardEntity "*" --> "1" CardEntity : cardId

legend right
  |= Couleur |= Signification |
  | <#1A1A2E> | Entité existante |
  | <#2A1A0A> | **[NEW]** Entité à créer |
  | <#0D1A2E> | Classe Core |
  --
  **v3.2 — Ajouts :**
  1. **CardDeckEntity** (1 boîte = 1 deck)
  2. **deckId** partout (cards, trios, sessions, codes)
  3. **qrCode** sur CardEntity (scan physique)
  4. **activeDeckId** sur UserEntity
  5. **ScanValidationEntity** (mode collectif)
  6. **GameMode** enum (solo/coop)
endlegend

@enduml
